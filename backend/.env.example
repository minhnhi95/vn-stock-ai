# Backend env vars cho production deploy
# Local dev: copy file này thành .env và điền — không có sẽ fallback default

# Neon Postgres (production). Lấy từ Neon dashboard → Connection Details.
# Format: postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/dbname?sslmode=require
# Để trống ở local dev → tự dùng SQLite file data.db
DATABASE_URL=

# CORS origins (comma-separated). VD: https://vn-stock-ai.vercel.app
# Local dev đã có defaults sẵn cho localhost:5273/5180/5173
CORS_ORIGINS=

# Optional: Gemini key fallback ở server (user có thể nhập key qua UI)
GEMINI_API_KEY=

# Optional: model override
GEMINI_MODEL=gemini-2.5-flash
